generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// SCHEMA GOVERNANCE
// This schema is the canonical merged schema for both the
// admin app and the student frontend. The admin app OWNS the
// database. The student frontend READS from it and adds its
// own runtime fields (Attempt.status, Test.code, etc.).
//
// CRITICAL RULES:
//   1. NEVER run `prisma db push --accept-data-loss` against
//      the shared production DB. This would DROP admin tables
//      and columns, causing irreversible data loss.
//   2. All shared-table field additions must be added to BOTH
//      the admin schema and this file to stay in sync.
//   3. Admin-only tables (Course, Video, etc.) exist in
//      the production DB but are NOT listed here — they are
//      managed exclusively by the admin app's schema.
//      As long as --accept-data-loss is never used from the
//      frontend, those tables are safe.
// ============================================================

// ENUMS (locked behavior)
enum UserRole {
  SUPER_ADMIN
  ADMIN
  STUDENT
}
enum SessionType {
  ADMIN
  STUDENT
}
enum EntitlementStatus {
  ACTIVE
  EXPIRED
  REVOKED
}
enum DifficultyLevel {
  FOUNDATIONAL  // 1★
  PROFICIENT    // 2★
  MASTERY       // 3★
}
enum QuestionStatus {
  DRAFT
  APPROVED
}
enum QuestionType {
  MCQ_SINGLE
  MCQ_MULTIPLE
  // Practice only
  DRAG_REORDER
  DRAG_DROP
  FILL_BLANKS
  TRUE_FALSE
}
enum ImportStatus {
  PREVIEWED
  VALIDATED
  PARTIAL_IMPORTED
  IMPORTED
  FAILED
}
enum TestMode {
  TIMED
  SECTIONAL
  MULTI_SECTION
}
enum RevenueStream {
  TESTHUB
  SELFPREP_HTML
  FLASHCARDS
  PDF_ACCESS
  SMART_PRACTICE
  AI_ADDON
}
enum CouponDiscountType {
  PERCENT
  FLAT
}
enum XpRuleKey {
  LOGIN_XP
  TEST_XP
  IMPROVEMENT_BONUS_XP
  FLASHCARD_XP
  RR_XP
}
enum LanguageAvailable {
  EN
  TE
  BOTH
}
enum AttemptStatus {
  IN_PROGRESS
  PAUSED
  SUBMITTED
}
// Admin flashcard enum (shared table FlashcardCard uses this)
enum FlashcardCardType {
  TITLE
  INFO
  QUIZ
  COMPARISON
  FILL_IN_BLANK
  MATCHING
  REORDER
  CATEGORIZATION
}

// CORE IDENTITY + SESSIONS (LOCKED)
model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  mobile       String?   @unique
  name         String?
  // Student-frontend fields
  fullName     String?
  state        String?
  gender       String?
  allowMultiDevice Boolean @default(false)
  // Admin management fields — owned by admin app, read-only for frontend
  isBlocked            Boolean   @default(false)
  blockedReason        String?
  maxWebDevices        Int       @default(1)
  deletedAt            DateTime?
  infringementWarnings Int       @default(0)
  infringementBlocked  Boolean   @default(false)
  mustChangePassword   Boolean   @default(false)
  legalAcceptedAt      DateTime?
  legalVersion         String?
  passwordHash String
  role         UserRole  @default(STUDENT)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions       Session[]
  entitlements   UserEntitlement[]
  attempts       Attempt[]
  xpEvents       XpEvent[]
  xpLedger       XpLedgerEntry[]
  auditLogs      AuditLog[] @relation("AuditActor")
  importJobs     ImportJob[]
  testSeries     TestSeries[]
  tests          Test[]
  flashcardDecks FlashcardDeck[]
  contentPages   ContentPage[]
  pdfAssets      PdfAsset[]
  coupons        Coupon[]
  xpRules        XpRule[]
  purchases      Purchase[]
  paymentOrders  PaymentOrder[]
  refundRequests RefundRequest[]
  @@index([role])
}
model Session {
  id         String      @id @default(cuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       SessionType @default(ADMIN)
  token      String      @unique
  expiresAt  DateTime
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  revokedAt  DateTime?
  @@index([userId, type])
  @@index([expiresAt])
}
// ENTITLEMENTS (LOCKED TABLE + FIELDS)
model UserEntitlement {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  productCode  String
  status       EntitlementStatus @default(ACTIVE)
  validUntil   DateTime?
  purchaseId   String?
  tenantId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([userId, productCode, tenantId])
  @@index([productCode, status])
}
// TAXONOMY (Category → Subject → Topic → Subtopic)
model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subjects  Subject[]
}
model Subject {
  id           String   @id @default(cuid())
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name         String
  subjectColor String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  topics       Topic[]
  @@unique([categoryId, name])
  @@index([categoryId])
}
model Topic {
  id        String   @id @default(cuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subtopics Subtopic[]
  @@unique([subjectId, name])
  @@index([subjectId])
}
model Subtopic {
  id      String @id @default(cuid())
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Restrict)
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  questions      Question[]
  flashcardCards FlashcardCard[]
  contentPages   ContentPage[]
  flashcardDecks FlashcardDeck[]
  @@unique([topicId, name])
  @@index([topicId])
}
// QUESTION BANK
model Question {
  id           String         @id @default(cuid())
  categoryId   String?
  subjectId    String?
  topicId      String?
  subtopicId   String?
  subtopic     Subtopic?      @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  type         QuestionType
  difficulty   DifficultyLevel
  status       QuestionStatus @default(DRAFT)
  stem         String
  // Admin bilingual columns: stem = primary language, stemSecondary = secondary language
  stemSecondary    String?
  explanation      String?
  explanationSecondary String?
  tags         String[]       @default([])
  contentHash  String         @unique
  options      QuestionOption[]
  testQuestions  TestQuestion[]
  attemptAnswers AttemptAnswer[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([type, status])
  @@index([difficulty])
  @@index([subtopicId])
}
model QuestionOption {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  // Admin bilingual column: text = primary language, textSecondary = secondary language
  textSecondary String?
  isCorrect  Boolean  @default(false)
  order      Int
  @@index([questionId])
}
// IMPORT SYSTEM (CSV & DOCX)
model ImportJob {
  id            String       @id @default(cuid())
  createdById   String
  createdBy     User         @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fileName      String
  fileType      String
  storageUrl    String?
  status        ImportStatus @default(PREVIEWED)
  totalRows     Int          @default(0)
  validRows     Int          @default(0)
  invalidRows   Int          @default(0)
  reportUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rows          ImportRow[]
  @@index([createdById, status])
}
model ImportRow {
  id          String    @id @default(cuid())
  importJobId String
  importJob   ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowNumber   Int
  rawData     Json
  editedData  Json?
  isValid     Boolean   @default(false)
  errorField  String?
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([importJobId, rowNumber])
  @@index([importJobId, isValid])
}
// TEST SERIES + TESTS + SECTIONS
model TestSeries {
  id           String   @id @default(cuid())
  title        String
  description  String?
  categoryId   String?
  subjectIds   String[] @default([])
  pricePaise   Int      @default(0)
  discountPaise Int     @default(0)
  currency     String   @default("INR")
  // Admin field — thumbnail for the series
  thumbnailUrl String?
  // Free-access flag: when true, all published tests in this series are freely accessible
  // without entitlement. Managed by admin. Price alone is NOT the source of truth for access.
  isFree       Boolean  @default(false)
  scheduleJson Json?
  isPublished  Boolean  @default(false)
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tests        Test[]
  @@index([isPublished])
}
model Test {
  id               String   @id @default(cuid())
  seriesId         String?
  series           TestSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  title            String
  instructions     String?
  mode             TestMode
  isTimed          Boolean  @default(true)
  durationSec      Int?
  allowPause       Boolean  @default(false)
  strictSectionMode Boolean @default(false)
  // Admin shuffle/xp fields — owned by admin app
  shuffleQuestions     Boolean  @default(false)
  shuffleOptions       Boolean  @default(false)
  shuffleGroups        Boolean  @default(false)
  shuffleGroupChildren Boolean  @default(false)
  xpEnabled            Boolean  @default(false)
  xpValue              Int      @default(0)
  testStartTime        DateTime?
  // Computed/denormalized question count
  totalQuestions       Int?     @default(0)
  isPublished  Boolean  @default(false)
  publishedAt  DateTime?
  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  // Student-frontend runtime fields
  code                     String?           @unique
  // Admin-managed free-access flag on individual tests
  // isFree=true means this specific test is freely accessible without entitlement.
  // See also TestSeries.isFree which unlocks all child tests.
  isFree                   Boolean           @default(false)
  languageAvailable        LanguageAvailable @default(BOTH)
  marksPerQuestion         Float?            @default(1)
  negativeMarksPerQuestion Float?            @default(0)
  attemptsAllowed          Int               @default(2)
  categoryId               String?
  subjectIds               String[]          @default([])
  syllabusTags             String[]          @default([])
  unlockAt                 DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  sections     TestSection[]
  questions    TestQuestion[]
  attempts     Attempt[]
  @@index([isPublished])
  @@index([seriesId])
  @@index([code])
}
model TestSection {
  id              String        @id @default(cuid())
  testId          String
  test            Test          @relation(fields: [testId], references: [id], onDelete: Cascade)
  // Admin nested-section support
  parentSectionId String?
  parentSection   TestSection?  @relation("SubsectionParent", fields: [parentSectionId], references: [id], onDelete: Cascade)
  subsections     TestSection[] @relation("SubsectionParent")
  title           String
  order           Int
  durationSec     Int?
  // Admin field — expected question count for sectional scoring
  targetCount     Int?
  questions       TestQuestion[]
  @@index([testId, order])
  @@index([parentSectionId])
}
model TestQuestion {
  id         String   @id @default(cuid())
  testId     String
  sectionId  String?
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  section    TestSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  order      Int
  // Admin per-question scoring — overrides test-level defaults when set
  marks         Float @default(1)
  negativeMarks Float @default(0)
  @@unique([testId, questionId])
  @@index([testId, order])
  @@index([sectionId, order])
}
// ATTEMPTS + RAPID REINFORCEMENT
model Attempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  // Student-frontend runtime fields
  status        AttemptStatus     @default(IN_PROGRESS)
  attemptNumber Int               @default(1)
  language      LanguageAvailable @default(EN)
  endsAt        DateTime?
  lockedSessionToken String?
  totalTimeUsedMs    Int          @default(0)
  startedAt    DateTime @default(now())
  submittedAt  DateTime?
  scorePct     Float    @default(0)
  correctCount Int      @default(0)
  wrongCount   Int      @default(0)
  unansweredCount Int   @default(0)
  rrGenerated  Boolean  @default(false)
  answers      AttemptAnswer[]
  pauseEvents  AttemptPause[]
  createdAt    DateTime @default(now())
  @@index([userId, startedAt])
  @@index([testId, startedAt])
  @@index([userId, testId, status])
}
model AttemptAnswer {
  id         String   @id @default(cuid())
  attemptId  String
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Restrict)
  // Admin original field
  selectedOptionIds String[] @default([])
  // Student-frontend additions
  selectedOptionId  String?
  isCorrect         Boolean  @default(false)
  isMarkedForReview Boolean  @default(false)
  timeSpentMs       Int      @default(0)
  savedAt           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}
model AttemptPause {
  id        String   @id @default(cuid())
  attemptId String
  attempt   Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  pausedAt  DateTime @default(now())
  resumedAt DateTime?
  @@index([attemptId])
}
// FLASHCARDS (Deck → Cards)
model FlashcardDeck {
  id             String  @id @default(cuid())
  title          String
  // Admin display fields
  subtitle       String?
  titleTemplate  String  @default("minimal_academic")
  titleImageUrl  String?
  subjectColor   String?
  xpEnabled      Boolean @default(false)
  xpValue        Int     @default(0)
  examId         String?
  description    String?
  categoryId     String?
  subjectId      String?
  topicId        String?
  subtopicId     String?
  subtopic       Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  isPublished    Boolean @default(false)
  unlockAt       DateTime?
  createdById    String
  createdBy      User    @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cards          FlashcardCard[]
}
model FlashcardCard {
  id         String        @id @default(cuid())
  deckId     String
  deck       FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  subtopicId String?
  subtopic   Subtopic?     @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  // Admin card type + rich content
  cardType   FlashcardCardType @default(INFO)
  content    Json?
  front      String
  back       String
  imageUrl   String?
  order      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  @@index([deckId, order])
}
// CONTENT LIBRARY
// Layer 1: HTML learning pages (Ebooks) — non-downloadable
// Layer 2: PDF library — downloadable
model ContentPage {
  id          String @id @default(cuid())
  title       String
  // Admin taxonomy fields
  categoryId  String?
  subjectId   String?
  topicId     String?
  subtopicId  String?
  subtopic    Subtopic? @relation(fields: [subtopicId], references: [id], onDelete: SetNull)
  // Admin XP fields
  xpEnabled   Boolean @default(false)
  xpValue     Int     @default(0)
  // Legacy single-page body — new ebooks use EBookPage chapters instead
  body        String
  isPublished Boolean @default(false)
  publishedAt DateTime?
  unlockAt    DateTime?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Restrict)
  ebookPages  EBookPage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([isPublished])
  @@index([subtopicId])
}

// Each EBookPage is one chapter/section of a multi-page ebook (ContentPage).
// Content is stored in contentHtml (rendered HTML) and/or contentBlocks (block JSON).
// orderIndex controls chapter sequence.
model EBookPage {
  id            String      @id @default(cuid())
  ebookId       String
  ebook         ContentPage @relation(fields: [ebookId], references: [id], onDelete: Cascade)
  title         String?
  contentHtml   String
  orderIndex    Int
  contentBlocks Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@index([ebookId, orderIndex])
}
model PdfAsset {
  id           String @id @default(cuid())
  title        String
  fileUrl      String
  fileSize     Int?
  mimeType     String? @default("application/pdf")
  categoryId   String?
  subjectId    String?
  topicId      String?
  subtopicId   String?
  // Admin field — controls whether students can download
  isDownloadable Boolean @default(true)
  isPublished  Boolean @default(false)
  publishedAt  DateTime?
  unlockAt     DateTime?
  createdById  String
  createdBy    User    @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([isPublished])
}
// PRODUCT BUILDER (packages → entitlements)
model ProductPackage {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  description      String?
  entitlementCodes String[] @default([])
  pricePaise       Int      @default(0)
  currency         String   @default("INR")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  purchases        Purchase[]
  paymentOrders    PaymentOrder[]
}
// COUPONS
model Coupon {
  id           String @id @default(cuid())
  code         String @unique
  discountType CouponDiscountType
  discountValue Int
  validFrom    DateTime?
  validUntil   DateTime?
  usageLimit   Int?
  perUserLimit Int?
  applicableEntitlements String[] @default([])
  isActive     Boolean @default(true)
  createdById  String
  createdBy    User    @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  purchases      Purchase[]
  paymentOrders  PaymentOrder[]
}
// XP RULE ENGINE + LEDGER
model XpRule {
  id          String    @id @default(cuid())
  key         XpRuleKey @unique
  value       Int
  isEnabled   Boolean   @default(true)
  dailyCap    Int?
  multiplier  Float     @default(1)
  updatedById String?
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
}
model XpEvent {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ruleKey   XpRuleKey
  points    Int
  meta      Json?
  createdAt DateTime  @default(now())
  @@index([userId, createdAt])
  @@index([ruleKey, createdAt])
}
model XpLedgerEntry {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  refType   String?
  refId     String?
  meta      Json?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}
// REVENUE + ANALYTICS
model Purchase {
  id           String @id @default(cuid())
  userId       String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId    String?
  package      ProductPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  couponId     String?
  coupon       Coupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  stream       RevenueStream
  currency     String @default("INR")
  grossPaise   Int
  feePaise     Int    @default(0)
  netPaise     Int
  // Admin legal consent tracking
  legalAcceptedAt DateTime?
  legalVersion    String?
  createdAt    DateTime @default(now())
  @@index([stream, createdAt])
  @@index([userId, createdAt])
}
// AUDIT LOGGING (LOCKED requirement)
model AuditLog {
  id         String  @id @default(cuid())
  actorId    String?
  actor      User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}

// ── PAYMENT ORDERS ────────────────────────────────────────────────────────────

enum PaymentOrderStatus {
  CREATED
  PENDING
  PAID
  FAILED
  CANCELLED
}

model PaymentOrder {
  id                String             @id @default(cuid())
  userId            String
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId         String
  package           ProductPackage     @relation(fields: [packageId], references: [id], onDelete: Restrict)
  couponId          String?
  coupon            Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  paymentConfigId   String?
  grossPaise        Int
  discountPaise     Int                @default(0)
  finalAmountPaise  Int
  currency          String             @default("INR")
  status            PaymentOrderStatus @default(CREATED)
  provider          String             @default("CASHFREE")
  providerOrderId   String?
  providerPaymentId String?
  paymentSessionId  String?
  legalAcceptedAt   DateTime?
  legalVersion      String?
  purchaseId        String?
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  refundRequests    RefundRequest[]
  @@index([userId, createdAt])
  @@index([status])
}

// ── REFUND REQUESTS ───────────────────────────────────────────────────────────

enum RefundReasonCategory {
  CHANGED_MIND
  TECHNICAL_ISSUE
  CONTENT_NOT_AS_DESCRIBED
  DUPLICATE_PURCHASE
  COURSE_NOT_STARTED
  OTHER
}

enum RefundRequestStatus {
  REQUESTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PROCESSED
  FAILED
  CANCELLED
}

model RefundRequest {
  id               String               @id @default(cuid())
  paymentOrderId   String
  paymentOrder     PaymentOrder         @relation(fields: [paymentOrderId], references: [id], onDelete: Restrict)
  userId           String
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId        String?
  packageName      String?
  packageCode      String?
  paidPaise        Int
  requestedPaise   Int?
  approvedPaise    Int?
  reasonCategory   RefundReasonCategory
  reasonText       String
  status           RefundRequestStatus  @default(REQUESTED)
  adminNote        String?
  reviewedById     String?
  reviewedAt       DateTime?
  processedById    String?
  processedAt      DateTime?
  gatewayRefundRef String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  @@index([userId, createdAt])
  @@index([paymentOrderId])
  @@index([status])
}
